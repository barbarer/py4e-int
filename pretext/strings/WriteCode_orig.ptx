      </block>
    </blocks>
    <solution>
      <p>Capture runtime input data arrays, isolate your structural starting index via position 0, and run <c>.lower()</c> adjustments.</p>
    </solution>
  </exercise>

  <exercise label="str-ex-lower-standalone">
    <statement>
      <p>Write a program that asks for user input and prints their input in all lowercase, as well as the length of their string.</p>
    </statement>
    <program xml:id="str-ex-loweracq" interactive="activecode" language="python">
      <code>
user_input = input("Enter a string: ")
print(user_input.lower() + " " + str(len(user_input)))

====
from unittest.gui import TestCaseGui
class myTests(TestCaseGui):
    def testOne(self):
        self.assertTrue(True)
myTests().main()
      </code>
    </program>
    <blocks xml:id="str-ex-loweransw" submission="program">
